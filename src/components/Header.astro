---
// src/components/Header.astro
// ✅ CHANGE: أُضيف رابط "تتبع طلبك" في القائمة الرئيسية
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<header>
  <a href="/" class="logo" aria-label="الصفحة الرئيسية - دورلي">
    <i class="fas fa-link pulse"></i> دورلي
  </a>

  <div class="header-actions">
    <button id="langToggleBtn" class="lang-toggle" title="تبديل اللغة">
      <span class="lang-label">ع</span>
    </button>
  </div>

  <nav id="mainNav">
    <a href="/" class={currentPath === "" ? "active" : ""}>
      <i class="fas fa-home"></i> <span data-i18n="home">الرئيسية</span>
    </a>
    <a href="/how-it-works" class={currentPath === "how-it-works" ? "active" : ""}>
      <i class="fas fa-question"></i> <span data-i18n="howItWorks">كيف يعمل</span>
    </a>
    <a href="/features" class={currentPath === "features" ? "active" : ""}>
      <i class="fas fa-gem"></i> <span data-i18n="features">الميزات</span>
    </a>
    <a href="/services" class={currentPath === "services" ? "active" : ""}>
      <i class="fas fa-cogs"></i> <span data-i18n="services">خدماتنا</span>
    </a>
    <!-- ✅ ADDED: رابط تتبع الطلب -->
    <a href="/track" class={currentPath === "track" ? "active" : ""}>
      <i class="fab fa-whatsapp"></i> <span data-i18n="trackOrder">تتبع طلبك</span>
    </a>
    <a href="/contact" class={currentPath === "contact" ? "active" : ""}>
      <i class="fas fa-envelope"></i> <span data-i18n="contact">تواصل معنا</span>
    </a>
    <a href="/pricing" class={currentPath === "pricing" ? "active" : ""}>
      <i class="fas fa-tags"></i> <span data-i18n="pricing">الباقات</span>
    </a>
    <a href="/request" class="services-btn">
      <i class="fas fa-paper-plane"></i> <span data-i18n="request">اطلب الآن</span>
    </a>
  </nav>

  <button id="mobileMenuBtn" class="mobile-menu-btn">
    <i class="fas fa-bars"></i>
  </button>
</header>

<script is:inline>
(function() {
  var LANG_KEY = 'dawerli_lang';

  var dict = {
    ar: {
      dir: 'rtl',
      home: 'الرئيسية', howItWorks: 'كيف يعمل', features: 'الميزات',
      services: 'خدماتنا', contact: 'تواصل معنا', pricing: 'الباقات',
      request: 'اطلب الآن',
      trackOrder: 'تتبع طلبك',
      heroTitle: 'حلقة الوصل بينك وبين ما تحتاج',
      heroDesc: 'منصة دورلي توفر لك كل ما تحتاجه من أي مدينة في ليبيا، بأسرع وقت وأقل تكلفة. نحن نبحث، نشتري، ونوصل لك!',
      heroOrderBtn: 'اطلب الآن', heroServicesBtn: 'تصفح الخدمات',
      howTitle: 'كيف يعمل دورلي؟', howSub: '3 خطوات بسيطة وطلبك في طريقه إليك',
      howStep1Title: 'أرسل طلبك', howStep1Desc: 'اكتب ما تحتاجه بالتفصيل عبر النموذج أو واتساب',
      howStep2Title: 'نبحث ونشتري', howStep2Desc: 'فريقنا يبحث ويشتري بأفضل سعر وجودة مضمونة',
      howStep3Title: 'نوصل لبابك', howStep3Desc: 'توصيل سريع وآمن لأي مدينة في ليبيا',
      howHeroTitle: 'كيف يعمل دورلي؟',
      howHeroDesc: 'أربع خطوات بسيطة فقط تفصلك عن الحصول على ما تريد.',
      hiwStep1Title: 'أخبرنا بما تحتاج', hiwStep1Desc: 'قم بتعبئة نموذج الطلب أو تواصل معنا عبر الواتساب.',
      hiwStep2Title: 'البحث والتسعير', hiwStep2Desc: 'فريقنا يبحث ويتواصل معك بالتكلفة الإجمالية.',
      hiwStep3Title: 'تأكيد الطلب والشراء', hiwStep3Desc: 'بعد موافقتك نشتري نيابة عنك ونجهز المنتج.',
      hiwStep4Title: 'الاستلام والدفع', hiwStep4Desc: 'مندوبنا يوصل لبابك، تتأكد ثم تدفع عند الاستلام.',
      langLabelShort: 'ع', themeToggleTitle: 'تبديل المظهر', logoAria: 'الصفحة الرئيسية - دورلي',
    },
    en: {
      dir: 'ltr',
      home: 'Home', howItWorks: 'How it works', features: 'Features',
      services: 'Services', contact: 'Contact', pricing: 'Pricing', request: 'Place order',
      trackOrder: 'Track Order',
      heroTitle: 'The connector between you and what you need',
      heroDesc: 'Dawerli finds, buys and delivers from any city in Libya — fast and affordably.',
      heroOrderBtn: 'Place order', heroServicesBtn: 'Browse services',
      howTitle: 'How Dawerli works', howSub: '3 simple steps and your order is on its way',
      howStep1Title: 'Send your request', howStep1Desc: 'Describe what you need via form or WhatsApp',
      howStep2Title: 'We search and buy', howStep2Desc: 'Our team finds the best price and quality',
      howStep3Title: 'We deliver to your door', howStep3Desc: 'Fast delivery to any Libyan city',
      howHeroTitle: 'How Dawerli works',
      howHeroDesc: 'Four simple steps to get what you need from anywhere in Libya.',
      hiwStep1Title: 'Tell us what you need', hiwStep1Desc: 'Fill the order form or contact us via WhatsApp.',
      hiwStep2Title: 'Search & Pricing', hiwStep2Desc: 'We search and contact you with total cost.',
      hiwStep3Title: 'Confirm & Purchase', hiwStep3Desc: 'We purchase on your behalf after approval.',
      hiwStep4Title: 'Receive & Pay', hiwStep4Desc: 'Delivered to your door. Pay on delivery.',
      langLabelShort: 'EN', themeToggleTitle: 'Toggle theme', logoAria: 'Home — Dawerli',
    }
  };

  function applyHeaderLang(lang) {
    var d = dict[lang] || dict['ar'];
    document.documentElement.lang = lang;
    document.documentElement.dir = d.dir;

    document.querySelectorAll('[data-i18n]').forEach(function(el) {
      var key = el.getAttribute('data-i18n');
      if (d[key] !== undefined) el.textContent = d[key];
    });

    var label = document.querySelector('.lang-label');
    if (label) label.textContent = d.langLabelShort || (lang === 'ar' ? 'ع' : 'EN');

    try { localStorage.setItem(LANG_KEY, lang); } catch(e) {}
  }

  function getSavedLang() {
    try { return localStorage.getItem(LANG_KEY) || 'ar'; } catch(e) { return 'ar'; }
  }

  applyHeaderLang(getSavedLang());

  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('langToggleBtn');
    if (btn) {
      var freshBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(freshBtn, btn);
      freshBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var current = getSavedLang();
        applyHeaderLang(current === 'ar' ? 'en' : 'ar');
      });
    }
  });
})();
</script>
