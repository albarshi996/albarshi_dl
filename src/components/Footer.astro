        <div class="contact-item">
          <i class="fab fa-whatsapp"></i>
          <a href={`https://wa.me/218${phone.substring(1)}`} target="_blank">{phone}</a>
        </div>
        <div class="contact-item">
          <i class="fas fa-envelope"></i>
          <a href={`mailto:${email}`}>{email}</a>
        </div>
      </div>
    </div>
  </div>
  <div class="copyright">
    <p>جميع الحقوق محفوظة &copy; {new Date().getFullYear()} لدى منصة دورلي</p>
