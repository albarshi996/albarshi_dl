---
import Layout from '../layouts/Layout.astro';
---

<Layout title="دورلي - الميزات" description="اكتشف الميزات التي تجعلنا الخيار الأول لتلبية احتياجاتك في كل مدن ليبيا بأمان، سرعة، وموثوقية.">
  <script is:inline>document.documentElement.dataset.page = 'features';</script>
  <section class="page-hero">
    <div class="hero-content reveal">
      <h1><span data-i18n="featuresTitle">لماذا تختار دورلي؟</span></h1>
      <p><span data-i18n="featuresDesc">اكتشف الميزات التي تجعلنا الخيار الأول لتلبية احتياجاتك في كل مدن ليبيا بأمان، سرعة، وموثوقية.</span></p>
    </div>
  </section>

  <section class="features-section">
    <div class="container reveal">
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
          <h3><span data-i18n="feat1Title">موثوقية وأمان عالي</span></h3>
          <p><span data-i18n="feat1Desc">نحن نضمن لك جودة المنتجات وسلامة أموالك. لن تدفع حتى تتأكد من طلبك وتستلمه يداً بيد.</span></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-bolt"></i></div>
          <h3><span data-i18n="feat2Title">سرعة في التنفيذ</span></h3>
          <p><span data-i18n="feat2Desc">بمجرد تأكيد طلبك، يبدأ فريقنا فوراً في البحث والشراء والتجهيز لضمان أسرع وقت ممكن للتوصيل.</span></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-tags"></i></div>
          <h3><span data-i18n="feat3Title">أفضل الأسعار</span></h3>
          <p><span data-i18n="feat3Desc">بحكم علاقتنا وتواجدنا المستمر في الأسواق، نضمن لك الحصول على أفضل سعر للمنتج بدون استغلال.</span></p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-map-marked-alt"></i></div>
          <h3><span data-i18n="feat4Title">تغطية واسعة</span></h3>
          <p><span data-i18n="feat4Desc">لا يهم أين تتواجد أنت أو أين يتواجد المنتج! نحن نربط بين مختلف المدن الليبية بكل سهولة.</span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container reveal">
      <div class="section-header">
        <h2>ما الذي ستحصل عليه أيضاً؟</h2>
        <p>خدمتنا لا تقتصر على الشراء والتوصيل، بل نقدم لك تجربة متكاملة لراحتك</p>
      </div>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon"><i class="fas fa-clock"></i></div>
          <h3>توفير وقتك وجهدك</h3>
          <p>تجنب زحام الأسواق وعناء السفر بين المدن للبحث عن قطع غيار نادرة أو بضاعة محددة؛ نحن نقوم بذلك نيابة عنك.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon"><i class="fas fa-headset"></i></div>
          <h3>متابعة مستمرة</h3>
          <p>فريقنا معك خطوة بخطوة عبر الواتساب، نرسل لك صور المنتج قبل شرائه لتأكيده ولتكون على اطلاع دائم.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon"><i class="fas fa-box-open"></i></div>
          <h3>تغليف احترافي وآمن</h3>
          <p>نحرص أشد الحرص على تغليف مقتنياتك والمواد القابلة للكسر بشكل ممتاز لتصلك سليمة 100%.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
