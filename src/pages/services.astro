---
import Layout from '../layouts/Layout.astro';
---

<Layout title="دورلي - خدماتنا" description="تصفح الفئات المختلفة لخدماتنا. ندور على أي شيء تحتاجه من أي مدينة في ليبيا.">
  <script is:inline>document.documentElement.dataset.page = 'services';</script>
  <style>
    .search-wrapper { max-width:600px; margin:-2rem auto 3rem; position:relative; z-index:10; padding:0 1rem; }
    .search-input { width:100%; padding:1.2rem 3.5rem 1.2rem 1.5rem; background:var(--glass-bg); border:2px solid var(--glass-border); border-radius:50px; color:white; font-size:1.1rem; backdrop-filter:blur(10px); outline:none; }
    .search-input:focus { border-color:var(--primary); }
    .search-icon { position:absolute; right:2.5rem; top:50%; transform:translateY(-50%); color:var(--text-muted); }
    .stat-badge { background:rgba(79,70,229,0.1); border:1px solid var(--primary); padding:0.5rem 1.2rem; border-radius:50px; font-size:0.9rem; color:var(--accent-light); margin:0 5px; display:inline-block; }
    .card-action-btn { display:block; width:100%; margin-top:1.5rem; padding:0.8rem; background:linear-gradient(135deg,var(--primary),var(--accent)); color:white; text-decoration:none; border-radius:12px; font-weight:700; text-align:center; font-size:0.9rem; transition:0.3s; }
    .card-action-btn:hover { transform:translateY(-3px); box-shadow:0 5px 15px rgba(6,182,212,0.3); }
    .hidden-card { display:none !important; }
    /* Photo-search highlight */
    .service-link-photo {
      background:rgba(6,182,212,0.1);
      border:1px solid rgba(6,182,212,0.35);
      border-radius:8px;
      padding:0.4rem 0.7rem;
      color:var(--accent-light) !important;
      font-weight:700;
    }
    .service-link-photo i { color:var(--accent) !important; }
    /* Card 5 glow — kept but now second-to-last; card 6 gets rose glow */
    .category-card:nth-child(5) { border-color:rgba(79,70,229,0.3); }
    .category-card:nth-child(5):hover { border-color:var(--primary); box-shadow:0 8px 30px rgba(79,70,229,0.15); }
    /* Card 6 — female audience (rose) */
    .category-card:last-child { border-color:rgba(236,72,153,0.35); }
    .category-card:last-child:hover { border-color:#ec4899; box-shadow:0 8px 30px rgba(236,72,153,0.2); }
  </style>

  <section class="page-hero">
    <div class="hero-content reveal">
      <h1><span data-i18n="servicesHeroTitle">خدماتنا المتنوعة</span></h1>
      <p><span data-i18n="servicesHeroDesc">تصفح الفئات المختلفة لخدماتنا. ندور على أي شيء تحتاجه، للمواطن والتاجر على حدٍّ سواء.</span></p>
    </div>
  </section>

  <div class="container">
    <div class="search-wrapper reveal">
      <i class="fas fa-search search-icon"></i>
      <input type="text" id="serviceSearch" class="search-input"
             data-i18n-placeholder="searchPlaceholder"
             placeholder="ابحث عن خدمة (مثلاً: رابش، عقار، جملة)...">
    </div>
    <div style="text-align:center;margin-bottom:3rem;" class="reveal">
      <span class="stat-badge"><i class="fas fa-th-large"></i> <span data-i18n="statBadgeCats">6 فئات رئيسية</span></span>
      <span class="stat-badge"><i class="fas fa-check-circle"></i> <span data-i18n="statBadgeServices">+30 خدمة متوفرة</span></span>
    </div>
  </div>

  <section class="services-categories">
    <div class="container reveal">
      <div class="categories-grid">

        <!-- ① رابش وقطع غيار -->
        <div class="category-card"
             data-keywords="رابش قطع غيار سيارات شاحنات محركات إطارات بطاريات معدات ثقيلة بحث صورة spare parts salvage truck car engine tires">
          <div class="category-header car-parts">
            <i class="fas fa-car-crash"></i>
            <h3><span data-i18n="catAutoparts">رابش وقطع غيار</span></h3>
          </div>
          <div class="category-services">
            <span class="service-link service-link-photo">
              <i class="fas fa-camera"></i> بحث عن قطع بالرابش بالصورة
            </span>
            <span class="service-link"><i class="fas fa-angle-left"></i> محركات ومعدات ثقيلة</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> إطارات وبطاريات جملة وقطاعي</span>
          </div>
          <a href="/request?cat=قطع غيار سيارات" class="card-action-btn">
            <span data-i18n="catAutoparts_btn">اطلب قطع غيار الآن</span>
          </a>
        </div>

        <!-- ② عقارات ومقرات -->
        <div class="category-card"
             data-keywords="عقارات إيجار شقق منازل مخازن مساحات تجارية أراضي استثمار مقرات property real estate warehouse rent">
          <div class="category-header"
               style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 15px rgba(245,158,11,0.25);">
            <i class="fas fa-building"></i>
            <h3><span data-i18n="catRealEstate">عقارات ومقرات</span></h3>
          </div>
          <div class="category-services">
            <span class="service-link"><i class="fas fa-angle-left"></i> شقق ومنازل للإيجار</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> مخازن ومساحات تجارية</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> أراضي واستثمار</span>
          </div>
          <a href="/request?cat=عقارات ومقرات" class="card-action-btn"
             style="background:linear-gradient(135deg,#f59e0b,#d97706);">
            <span data-i18n="catRealEstate_btn">اطلب بحث عقاري الآن</span>
          </a>
        </div>

        <!-- ③ بضائع جملة وتجهيز محلات -->
        <div class="category-card"
             data-keywords="بضائع جملة تجهيز محلات مطاعم مواد غذائية بناء تشطيب wholesale food construction restaurant shop fitting">
          <div class="category-header"
               style="background:linear-gradient(135deg,#10b981,#059669);box-shadow:0 4px 15px rgba(16,185,129,0.25);">
            <i class="fas fa-store"></i>
            <h3><span data-i18n="catWholesale">بضائع جملة وتجهيز محلات</span></h3>
          </div>
          <div class="category-services">
            <span class="service-link"><i class="fas fa-angle-left"></i> مواد غذائية بالجملة</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> تجهيز محلات ومطاعم</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> مواد بناء وتشطيب</span>
          </div>
          <a href="/request?cat=بضائع جملة" class="card-action-btn"
             style="background:linear-gradient(135deg,#10b981,#059669);">
            <span data-i18n="catWholesale_btn">اطلب بضائع جملة الآن</span>
          </a>
        </div>

        <!-- ④ أوراق ومستندات -->
        <div class="category-card"
             data-keywords="أوراق مستندات بريد معاملات جوازات تخليص بين المدن documents papers courier clearance">
          <div class="category-header documents">
            <i class="fas fa-file-alt"></i>
            <h3><span data-i18n="catDocs">أوراق ومستندات</span></h3>
          </div>
          <div class="category-services">
            <span class="service-link"><i class="fas fa-angle-left"></i> استلام وتوصيل أوراق</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> التخليص بين المدن</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> بريد سريع وعاجل</span>
          </div>
          <a href="/request?cat=أوراق ومستندات" class="card-action-btn">
            <span data-i18n="catDocs_btn">اطلب توصيل أوراق الآن</span>
          </a>
        </div>

        <!-- ⑤ ندورلك على أي شيء! -->
        <div class="category-card"
             data-keywords="ندورلك بحث صورة نادر متاجر إلكترونية خاص مخصص أي شيء find anything custom rare online shopping">
          <div class="category-header custom-service">
            <i class="fas fa-magic"></i>
            <h3><span data-i18n="catNadawrLak">ندورلك على أي شيء!</span></h3>
          </div>
          <div class="category-services">
            <span class="service-link service-link-photo">
              <i class="fas fa-camera"></i> أرسل صورة لطلبك وسنجده
            </span>
            <span class="service-link"><i class="fas fa-angle-left"></i> شراء من متاجر إلكترونية</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> طلبات نادرة</span>
          </div>
          <a href="/request?cat=أخرى" class="card-action-btn">
            <span data-i18n="catNadawrLak_btn">ندور لك على ما تريد</span>
          </a>
        </div>


        <!-- ⑥ تسوق، صحة، وتجميل — Female demographic -->
        <div class="category-card"
             data-keywords="تجميل مكياج بشرة عناية أزياء فساتين ملابس نساء دواء صيدلية صحة makeup beauty skincare clothes pharmacy medicine women health dress">
          <div class="category-header"
               style="background:linear-gradient(135deg,#ec4899,#be185d);box-shadow:0 4px 15px rgba(236,72,153,0.3);">
            <i class="fas fa-shopping-bag"></i>
            <h3><span data-i18n="catBeautyHealth">تسوق، صحة، وتجميل</span></h3>
          </div>
          <div class="category-services">
            <span class="service-link"><i class="fas fa-angle-left"></i> مستحضرات تجميل وعناية بالبشرة</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> أزياء، فساتين، ومستلزمات نسائية</span>
            <span class="service-link"><i class="fas fa-angle-left"></i> أدوية ومستلزمات صيدلية غير متوفرة</span>
          </div>
          <a href="/request?cat=تسوق وتجميل" class="card-action-btn"
             style="background:linear-gradient(135deg,#ec4899,#be185d);">
            <span data-i18n="catBeautyHealth_btn">اطلبي منتجاتك الآن</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var inp   = document.getElementById('serviceSearch');
      var cards = document.querySelectorAll('.category-card');
      if (!inp) return;
      inp.addEventListener('input', function(e) {
        var term = e.target.value.toLowerCase().trim();
        cards.forEach(function(card) {
          if (!term) { card.classList.remove('hidden-card'); return; }
          /* Search in visible text AND data-keywords (Arabic + English aliases) */
          var hay = (card.innerText + ' ' + (card.dataset.keywords || '')).toLowerCase();
          card.classList.toggle('hidden-card', !hay.includes(term));
        });
      });
    })();
  </script>
</Layout>
