---
import Layout from '../layouts/Layout.astro';
---

<Layout title="دورلي - خدماتنا" description="تصفح الفئات المختلفة لخدماتنا. نحن نغطي تقريباً كل ما قد تحتاجه من أي مدينة في ليبيا.">
  <section class="page-hero">
    <div class="hero-content reveal">
      <h1>خدماتنا المتنوعة</h1>
      <p>تصفح الفئات المختلفة لخدماتنا. نحن نغطي تقريباً كل ما قد تحتاجه، وإذا لم تجد طلبك، يمكنك دائماً استخدام "البحث المخصص".</p>
    </div>
  </section>

  <section class="services-categories">
    <div class="container reveal">
      <div class="categories-grid">
        
        <div class="category-card">
          <div class="category-header car-parts">
            <i class="fas fa-car"></i>
            <h3>قطع غيار السيارات</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> قطع غيار محركات</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> إكسسوارات وزينة</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> إطارات وبطاريات</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header truck-parts">
            <i class="fas fa-truck-moving"></i>
            <h3>قطع غيار الشاحنات</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> قطع غيار النقل الثقيل</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> زيوت ومستهلكات</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> معدات ثقيلة</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header food-items">
            <i class="fas fa-hamburger"></i>
            <h3>مواد غذائية وحلويات</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> حلويات المناسبات</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> منتجات المدن التراثية</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> جملة المواد الغذائية</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header documents">
            <i class="fas fa-file-alt"></i>
            <h3>أوراق ومستندات</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> استلام وتوصيل أوراق</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> تخليص إجراءات بسيطة</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> بريد سريع بين المدن</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header wedding-items">
            <i class="fas fa-ring"></i>
            <h3>مستلزمات الأفراح</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> ملابس وتجهيزات العروس</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> مواد زينة وديكور</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> توزيعات المناسبات</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header beauty-cleaning">
            <i class="fas fa-spray-can"></i>
            <h3>التجميل والنظافة</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> مستحضرات التجميل</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> منتجات العناية بالبشرة</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> مواد تنظيف بالجملة</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header construction">
            <i class="fas fa-hard-hat"></i>
            <h3>مواد البناء والصيانة</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> مواد تشطيب وديكور</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> أدوات صحية وكهربائية</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> معدات صيانة خفيفة</a>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header custom-service">
            <i class="fas fa-magic"></i>
            <h3>خدمات مخصصة</h3>
          </div>
          <div class="category-services">
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> بحث عن منتج نادر</a>
            <a href="/request" class="service-link"><i class="fas fa-angle-left"></i> شراء من متاجر إلكترونية</a>
            <a href="https://wa.me/218946507954" target="_blank" class="service-link"><i class="fas fa-angle-left"></i> استشارة وتواصل مباشر</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="quick-search-section">
    <div class="container reveal">
      <div class="section-header">
        <h2>لم تجد ما تبحث عنه؟</h2>
        <p>لا تقلق، فقط اضغط على الزر أدناه وسنبحث عنه من أجلك</p>
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/request" class="hero-btn" style="font-size: 1.2rem; padding: 1.5rem 3rem;">
          اطلب خدمة خاصة <i class="fas fa-arrow-left"></i>
        </a>
      </div>
    </div>
  </section>
</Layout>
