---
import Layout from '../layouts/Layout.astro';

// ── Moamalat credentials — read from .env at Astro build time ────
// In production: set these as GitHub repository secrets, NOT in .env
const MID          = import.meta.env.MOAMALAT_MERCHANT_ID  || '10081014740';
const TID          = import.meta.env.MOAMALAT_TERMINAL_ID  || '99881350';
const SK           = import.meta.env.MOAMALAT_SECRET_KEY   || 'C187BF0E0A1F42F1888EA9BDCE6DF0C05AD3B4CE2B5AC2A71A8C3A8AC0F69348';
const MOAMALAT_ENV = import.meta.env.MOAMALAT_ENV          || 'sandbox';
const CCY          = import.meta.env.MOAMALAT_CURRENCY     || '434';
const SANDBOX_URL  = import.meta.env.MOAMALAT_SANDBOX_URL  || 'https://demo.moamalat.net';
---

<Layout
  title="دورلي — بوابة الدفع التجريبية"
  description="صفحة دفع تجريبية Sandbox لمنصة دورلي. لن يتم إجراء أي خصم مالي حقيقي."
  noindex={true}
>
  <script is:inline>document.documentElement.dataset.page = 'checkout';</script>

  <!-- ══════════════════════════════════════════════════════════════
       CREDENTIALS CONFIG — injected at build time from .env
       JS reads via data attributes (never stored in global scope)
       ══════════════════════════════════════════════════════════════ -->
  <div id="moaConfig" hidden
       data-mid={MID}
       data-tid={TID}
       data-sk={SK}
       data-env={MOAMALAT_ENV}
       data-ccy={CCY}
       data-sandbox-url={SANDBOX_URL}></div>

  <style>
    /* ── Sandbox Banner ─────────────────────────────────────────────── */
    .sandbox-banner {
      position: sticky; top: 0; z-index: 1002;
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: #1c1917; text-align: center;
      padding: 0.75rem 1.2rem; font-size: 0.95rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center; gap: 0.6rem;
      box-shadow: 0 2px 12px rgba(245,158,11,0.5);
    }
    .sandbox-banner i { font-size: 1.1rem; }
    .sandbox-badge {
      background: #1c1917; color: #fbbf24;
      padding: 0.15rem 0.6rem; border-radius: 6px;
      font-size: 0.8rem; letter-spacing: 0.05em; margin-right: 0.4rem;
    }
    /* ── Checkout Layout ────────────────────────────────────────────── */
    .checkout-wrapper {
      max-width: 860px; margin: 2rem auto;
      padding: 0 1rem 4rem;
      display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
      align-items: start;
    }
    @media (max-width: 700px) { .checkout-wrapper { grid-template-columns: 1fr; } }
    /* ── Shared card ────────────────────────────────────────────────── */
    .co-card {
      background: var(--glass-bg); border: 1px solid var(--glass-border);
      border-radius: var(--border-radius-lg); padding: 1.8rem;
      backdrop-filter: blur(10px);
    }
    .co-card h2 {
      font-size: 1.1rem; font-weight: 800; color: var(--white);
      margin-bottom: 1.4rem; display: flex; align-items: center; gap: 0.5rem;
    }
    /* ── Order summary ──────────────────────────────────────────────── */
    .order-line {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.65rem 0; border-bottom: 1px solid var(--glass-border);
      font-size: 0.88rem;
    }
    .order-line:last-child { border-bottom: none; }
    .order-line .lbl { color: var(--text-muted); }
    .order-line .val { color: var(--text-main); font-weight: 600; }
    .order-total {
      margin-top: 1rem; padding: 1rem;
      background: rgba(79,70,229,0.1); border: 1px solid var(--primary);
      border-radius: 12px; display: flex; justify-content: space-between; align-items: center;
    }
    .order-total .t-lbl { font-weight: 700; color: var(--white); }
    .order-total .t-amt {
      font-size: 1.5rem; font-weight: 900;
      background: linear-gradient(135deg, var(--primary-light), var(--accent));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    /* ── Test cards ─────────────────────────────────────────────────── */
    .test-cards {
      margin-top: 1.3rem; padding: 1rem;
      background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.25);
      border-radius: 12px;
    }
    .test-cards-title {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.82rem; font-weight: 700; color: #6ee7b7; margin-bottom: 0.6rem;
    }
    .test-cards-grid {
      font-family: monospace; font-size: 0.77rem; line-height: 1.9;
      color: var(--text-muted);
    }
    /* ── Hash debug panel ───────────────────────────────────────────── */
    .hash-panel {
      margin-top: 1rem; padding: 0.9rem;
      background: rgba(79,70,229,0.06); border: 1px solid rgba(79,70,229,0.25);
      border-radius: 10px; font-size: 0.73rem; color: var(--text-muted);
    }
    .hash-panel strong { color: var(--accent-light); display: block; margin-bottom: 0.3rem; }
    .hash-value {
      font-family: monospace; word-break: break-all;
      color: #a5b4fc; font-size: 0.68rem;
    }
    .hash-input-str { font-family: monospace; color: #94a3b8; font-size: 0.68rem; word-break: break-all; }
    /* ── Payment form ───────────────────────────────────────────────── */
    .fg { margin-bottom: 1.05rem; }
    .fg label {
      display: flex; align-items: center; gap: 0.4rem;
      font-size: 0.84rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.45rem;
    }
    .fg input, .fg select {
      width: 100%; padding: 0.82rem 1rem;
      background: var(--bg-card); border: 1px solid var(--glass-border);
      border-radius: 12px; color: var(--text-main);
      font-family: 'Tajawal', sans-serif; font-size: 1rem;
      transition: border-color 0.2s; direction: ltr; text-align: left;
    }
    .fg input:focus, .fg select:focus { outline: none; border-color: var(--primary); }
    .fg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
    .cn-wrap { position: relative; }
    .cn-icon {
      position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
      font-size: 1.3rem; color: var(--text-muted); pointer-events: none;
    }
    #cardNumber { padding-left: 3rem; letter-spacing: 0.12em; }
    /* ── Pay button ─────────────────────────────────────────────────── */
    .pay-btn {
      width: 100%; padding: 1.05rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white; border: none; border-radius: 14px;
      font-family: 'Tajawal', sans-serif; font-size: 1.1rem; font-weight: 800;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      gap: 0.7rem; transition: all 0.25s; margin-top: 0.4rem;
    }
    .pay-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(79,70,229,0.4); }
    .pay-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .spinner {
      width: 20px; height: 20px;
      border: 3px solid rgba(255,255,255,0.3); border-top-color: white;
      border-radius: 50%; animation: spin 0.8s linear infinite; display: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .secure-note {
      display: flex; align-items: center; gap: 0.4rem;
      justify-content: center; font-size: 0.76rem; color: var(--text-muted); margin-top: 0.75rem;
    }
    .secure-note i { color: #10b981; }
    /* ── Result modal ───────────────────────────────────────────────── */
    .result-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(5,5,5,0.93); z-index: 9999;
      align-items: center; justify-content: center; padding: 1.5rem;
    }
    .result-overlay.show { display: flex; }
    .result-modal {
      background: var(--bg-card); border: 1px solid var(--glass-border);
      border-radius: 20px; padding: 2.5rem 2rem; text-align: center;
      max-width: 430px; width: 100%;
      animation: popIn 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes popIn { from{opacity:0;transform:scale(0.85)} to{opacity:1;transform:scale(1)} }
    .result-icon {
      width: 72px; height: 72px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem; margin: 0 auto 1.2rem;
    }
    .result-icon.s { background: rgba(16,185,129,0.2); color: #10b981; border: 2px solid #10b981; }
    .result-icon.f { background: rgba(239,68,68,0.2);  color: #ef4444; border: 2px solid #ef4444; }
    .result-modal h3 { font-size: 1.3rem; font-weight: 800; color: var(--white); margin-bottom: 0.5rem; }
    .result-modal p  { color: var(--text-muted); font-size: 0.88rem; line-height: 1.6; margin-bottom: 1.4rem; }
    .result-ref {
      display: inline-block; background: rgba(79,70,229,0.15);
      border: 1px solid var(--primary); border-radius: 8px;
      padding: 0.35rem 1rem; font-size: 0.82rem; color: var(--accent-light);
      font-family: monospace; margin-bottom: 1.4rem;
    }
    .result-btn {
      display: inline-block; padding: 0.82rem 2rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white; border: none; border-radius: 50px;
      font-family: 'Tajawal', sans-serif; font-size: 1rem; font-weight: 700;
      cursor: pointer; text-decoration: none; transition: all 0.2s;
    }
    .result-btn:hover { transform: translateY(-2px); }
    /* ── Tech note ──────────────────────────────────────────────────── */
    .tech-note {
      max-width: 860px; margin: 0 auto 1.5rem; padding: 0.9rem 1.4rem;
      background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.22);
      border-radius: 12px; font-size: 0.8rem; color: #fca5a5;
      display: flex; gap: 0.75rem; align-items: flex-start;
    }
    .tech-note i { flex-shrink: 0; margin-top: 0.1rem; color: #ef4444; }
    @media(max-width:480px){.sandbox-banner{font-size:0.8rem;flex-wrap:wrap;}}
  </style>

  <!-- ⚠️ SANDBOX WARNING BANNER (Anti-Fraud Rule #1 — sticky, always visible) -->
  <div class="sandbox-banner" role="alert" aria-live="assertive">
    <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
    <span class="sandbox-badge">SANDBOX</span>
    <strong>بيئة تجريبية (Sandbox Mode)</strong>&nbsp;—&nbsp;لن يتم إجراء أي خصم مالي حقيقي
  </div>

  <section class="page-hero" style="padding-bottom:1.5rem;">
    <div class="hero-content">
      <h1 style="font-size:1.8rem;">
        <i class="fas fa-credit-card" style="color:var(--accent);"></i>
        بوابة الدفع الإلكتروني
        <span style="font-size:0.72rem;background:rgba(245,158,11,0.2);color:#fbbf24;padding:0.2rem 0.7rem;border-radius:20px;vertical-align:middle;margin-right:0.5rem;">SANDBOX</span>
      </h1>
      <p style="font-size:0.92rem;">مدعومة بتقنية معاملات (Moamalat) · SHA-512 SecureHash · TLS 1.3</p>
    </div>
  </section>

  <!-- Tech disclaimer -->
  <div class="tech-note">
    <i class="fas fa-info-circle"></i>
    <span>
      <strong>للمطورين:</strong> يتم حساب SecureHash بـ <code>SHA-512(MID+TID+Amount+CCY+DateTime+OrderRef+SecretKey)</code> عبر
      <code>window.crypto.subtle.digest</code>. في بيئة الإنتاج يجب نقل هذه العملية لـ API endpoint على الخادم لمنع كشف SecretKey.
      لا تُدخل بيانات بطاقة حقيقية — استخدم أرقام الاختبار المذكورة.
    </span>
  </div>

  <div class="checkout-wrapper">

    <!-- ① Order Summary + Debug Panel -->
    <aside class="co-card" aria-label="ملخص الطلب">
      <h2><i class="fas fa-receipt"></i> ملخص الطلب</h2>

      <div class="order-line"><span class="lbl">رقم الطلب</span><span class="val" id="sumRef">DW-2026-—</span></div>
      <div class="order-line"><span class="lbl">الخدمة</span><span class="val" id="sumCat">—</span></div>
      <div class="order-line"><span class="lbl">المدينة</span><span class="val" id="sumCity">—</span></div>
      <div class="order-line"><span class="lbl">الكمية</span><span class="val" id="sumQty">1</span></div>
      <div class="order-line"><span class="lbl">رسوم الخدمة</span><span class="val" id="sumFee">20 د.ل</span></div>
      <div class="order-total">
        <span class="t-lbl">الإجمالي</span>
        <span class="t-amt" id="sumTotal">20 د.ل</span>
      </div>

      <!-- SHA-512 SecureHash debug (sandbox only) -->
      <div class="hash-panel" id="hashPanel">
        <strong><i class="fas fa-fingerprint"></i> SecureHash (SHA-512) — مباشر:</strong>
        <div style="margin-bottom:0.4rem;color:#94a3b8;font-size:0.7rem;">المدخلات:</div>
        <div class="hash-input-str" id="hashInput">—</div>
        <div style="margin-top:0.5rem;margin-bottom:0.3rem;color:#94a3b8;font-size:0.7rem;">الناتج (SHA-512):</div>
        <div class="hash-value" id="hashValue">جارٍ الحساب...</div>
      </div>

      <!-- Test cards reference -->
      <div class="test-cards">
        <div class="test-cards-title"><i class="fas fa-credit-card"></i> بطاقات الاختبار (Moamalat Sandbox)</div>
        <div class="test-cards-grid">
          ✅ VISA:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;4111 1111 1111 1111<br>
          ✅ Mastercard: 5500 0000 0000 0004<br>
          📅 انتهاء:&nbsp;&nbsp;&nbsp;أي تاريخ مستقبلي<br>
          🔒 CVV:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;أي 3 أرقام
        </div>
      </div>

      <div style="margin-top:1.3rem;text-align:center;padding-top:1rem;border-top:1px solid var(--glass-border);">
        <div style="font-size:0.72rem;color:var(--text-muted);">Powered by</div>
        <div style="font-size:1rem;font-weight:800;color:var(--accent-light);letter-spacing:0.05em;">معاملات · Moamalat</div>
        <div style="font-size:0.68rem;color:var(--text-muted);margin-top:0.15rem;" id="envBadge">Sandbox v2.0</div>
      </div>
    </aside>

    <!-- ② Payment Form -->
    <section class="co-card" aria-label="نموذج الدفع">
      <h2><i class="fas fa-lock"></i> بيانات الدفع</h2>

      <form id="paymentForm" autocomplete="off" novalidate>

        <div class="fg">
          <label for="cardName"><i class="fas fa-user"></i> اسم حامل البطاقة</label>
          <input type="text" id="cardName" placeholder="FULL NAME (as on card)"
                 autocomplete="cc-name" required>
        </div>

        <div class="fg">
          <label for="cardNumber"><i class="fas fa-credit-card"></i> رقم البطاقة</label>
          <div class="cn-wrap">
            <i class="fas fa-credit-card cn-icon" id="cardTypeIcon"></i>
            <input type="text" id="cardNumber" placeholder="0000  0000  0000  0000"
                   inputmode="numeric" maxlength="19" autocomplete="cc-number" required>
          </div>
        </div>

        <div class="fg-row">
          <div class="fg">
            <label for="expiry"><i class="fas fa-calendar-alt"></i> تاريخ الانتهاء</label>
            <input type="text" id="expiry" placeholder="MM / YY"
                   inputmode="numeric" maxlength="7" autocomplete="cc-exp" required>
          </div>
          <div class="fg">
            <label for="cvv"><i class="fas fa-shield-alt"></i> CVV</label>
            <input type="text" id="cvv" placeholder="•••"
                   inputmode="numeric" maxlength="4" autocomplete="cc-csc" required>
          </div>
        </div>

        <div class="fg">
          <label for="amount"><i class="fas fa-money-bill-wave"></i> المبلغ (دينار ليبي)</label>
          <input type="number" id="amount" min="1" max="99999" value="20" required>
        </div>

        <button type="submit" class="pay-btn" id="payBtn">
          <span class="spinner" id="paySpinner"></span>
          <i class="fas fa-lock" id="payIcon"></i>
          <span id="payText">إتمام الدفع (Sandbox)</span>
        </button>

        <p class="secure-note">
          <i class="fas fa-shield-alt"></i>
          SHA-512 SecureHash · TLS 1.3 · PCI-DSS Compliant (Sandbox)
        </p>
      </form>
    </section>

  </div>

  <!-- Result Modal -->
  <div class="result-overlay" id="resultOverlay" role="dialog" aria-modal="true">
    <div class="result-modal">
      <div class="result-icon s" id="resultIcon">
        <i class="fas fa-check-circle" id="resultIconI"></i>
      </div>
      <h3 id="resultTitle">تمت العملية!</h3>
      <p id="resultMsg"></p>
      <div class="result-ref" id="resultRef">TXN-SANDBOX-0000</div><br>
      <a href="/" class="result-btn" id="resultBtn">العودة للرئيسية</a>
    </div>
  </div>

  <script is:inline>
  (function () {
    'use strict';

    /* ── Read credentials injected at build time ────────────────────── */
    var cfg = document.getElementById('moaConfig').dataset;
    var MID = cfg.mid;
    var TID = cfg.tid;
    var SK  = cfg.sk;
    var CCY = cfg.ccy;
    var ENV = cfg.env;

    document.getElementById('envBadge').textContent =
      (ENV === 'sandbox' ? 'Sandbox' : 'Production') + ' · Moamalat v2';

    /* ── Populate order summary from URL params ──────────────────────── */
    var p = new URLSearchParams(window.location.search);
    var orderRef = p.get('ref')  || ('DW-2026-' + (Math.floor(Math.random()*9000)+1000));
    var cat      = p.get('cat')  || 'توصيل عادي';
    var city     = p.get('city') || '—';
    var qty      = p.get('qty')  || '1';
    var fee      = parseInt(p.get('fee') || '20', 10);

    function $(id){ return document.getElementById(id); }

    $('sumRef').textContent   = orderRef;
    $('sumCat').textContent   = cat;
    $('sumCity').textContent  = city;
    $('sumQty').textContent   = qty;
    $('sumFee').textContent   = fee + ' د.ل';
    $('sumTotal').textContent = fee + ' د.ل';
    $('amount').value         = fee;

    /* ════════════════════════════════════════════════════════════════
       SHA-512 via Web Crypto API (async)
       Moamalat Hash Formula:
         hashInput = MID + TID + TotalAmount(milliemes) + CCY + DateTime + OrderRef
         SecureHash = SHA512(hashInput + SK).toUpperCase()
    ════════════════════════════════════════════════════════════════ */
    async function sha512hex(str) {
      var data = new TextEncoder().encode(str);
      var buf  = await window.crypto.subtle.digest('SHA-512', data);
      return Array.from(new Uint8Array(buf))
        .map(function(b){ return b.toString(16).padStart(2,'0'); })
        .join('').toUpperCase();
    }

    function getDateTime() {
      var n = new Date();
      var z = function(x){ return String(x).padStart(2,'0'); };
      return n.getFullYear() + z(n.getMonth()+1) + z(n.getDate()) +
             z(n.getHours()) + z(n.getMinutes()) + z(n.getSeconds());
    }

    function genTxnRef() {
      return 'TXN-SB-' + Date.now().toString(36).toUpperCase() +
             '-' + Math.random().toString(36).substr(2,4).toUpperCase();
    }

    /* Build Moamalat Sandbox Request Object + compute SecureHash */
    async function buildMoamalatRequest(amountLYD, txnRef) {
      var dt        = getDateTime();
      var totalMs   = String(amountLYD * 1000);   // Convert to milliemes (1 LYD = 1000 milliemes)
      /* Moamalat standard hash input (field order per docs.moamalat.net) */
      var hashInput = MID + TID + totalMs + CCY + dt + txnRef;
      var secureHash = await sha512hex(hashInput + SK);

      return {
        MerchantID:      MID,
        TerminalID:      TID,
        TotalAmount:     totalMs,
        Currency:        CCY,
        DateTime:        dt,
        MerchantReference: txnRef,
        OrderDescription: 'Dawerli Delivery - ' + cat,
        ReturnURL:       window.location.origin + '/checkout/result',
        SecureHashType:  'SHA512',
        SecureHash:      secureHash,
        /* ── Hash debug info (sandbox only — remove in production) ── */
        _debug: { hashInput: hashInput, secureHash: secureHash }
      };
    }

    /* Compute initial hash for display on page load */
    (async function initHashDisplay() {
      try {
        var initTxn = genTxnRef();
        var req = await buildMoamalatRequest(fee, initTxn);
        $('hashInput').textContent  = req._debug.hashInput;
        $('hashValue').textContent  = req._debug.secureHash;
      } catch(e) {
        $('hashValue').textContent = 'WebCrypto not available: ' + e.message;
      }
    })();

    /* ── Card number formatting + type detection ─────────────────────── */
    $('cardNumber').addEventListener('input', function(e) {
      var v = e.target.value.replace(/\D/g,'').slice(0,16);
      e.target.value = v.replace(/(.{4})/g,'$1  ').trim();
      var icon = $('cardTypeIcon');
      if      (/^4/.test(v)) { icon.className='fab fa-cc-visa cn-icon'; icon.style.color='#1a56db'; }
      else if (/^5/.test(v)) { icon.className='fab fa-cc-mastercard cn-icon'; icon.style.color='#e02424'; }
      else if (/^3/.test(v)) { icon.className='fab fa-cc-amex cn-icon'; icon.style.color='#1e88e5'; }
      else                    { icon.className='fas fa-credit-card cn-icon'; icon.style.color=''; }
    });

    /* ── Expiry format ───────────────────────────────────────────────── */
    $('expiry').addEventListener('input', function(e) {
      var v = e.target.value.replace(/\D/g,'').slice(0,4);
      e.target.value = v.length >= 3 ? v.slice(0,2) + ' / ' + v.slice(2) : v;
    });

    /* ── CVV: numeric only ───────────────────────────────────────────── */
    $('cvv').addEventListener('input', function(e) {
      e.target.value = e.target.value.replace(/\D/g,'').slice(0,4);
    });

    /* ── Amount change → recompute hash display ─────────────────────── */
    $('amount').addEventListener('change', async function() {
      var a = parseInt(this.value, 10) || 20;
      $('sumFee').textContent   = a + ' د.ل';
      $('sumTotal').textContent = a + ' د.ل';
      try {
        var req = await buildMoamalatRequest(a, genTxnRef());
        $('hashInput').textContent = req._debug.hashInput;
        $('hashValue').textContent = req._debug.secureHash;
      } catch(e) {}
    });

    /* ── Form submit ─────────────────────────────────────────────────── */
    $('paymentForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var cn  = $('cardNumber').value.replace(/\s/g,'');
      var exp = $('expiry').value;
      var cvv = $('cvv').value;
      var nm  = $('cardName').value.trim();
      var amt = parseInt($('amount').value, 10) || 20;

      if (cn.length < 13 || !exp || cvv.length < 3 || !nm) {
        alert('يرجى إدخال بيانات البطاقة كاملةً (استخدم بطاقة الاختبار المذكورة)');
        return;
      }

      /* Loading state */
      var btn = $('payBtn');
      btn.disabled = true;
      $('paySpinner').style.display = 'block';
      $('payIcon').style.display    = 'none';
      $('payText').textContent      = 'جارٍ حساب SecureHash وإرسال الطلب...';

      try {
        var txnRef = genTxnRef();
        var req    = await buildMoamalatRequest(amt, txnRef);

        /* Update hash display with final values */
        $('hashInput').textContent = req._debug.hashInput;
        $('hashValue').textContent = req._debug.secureHash;

        /* Log full Moamalat payload for debugging */
        console.info('[Dawerli Sandbox] Moamalat Request Payload:', JSON.stringify({
          MerchantID:        req.MerchantID,
          TerminalID:        req.TerminalID,
          TotalAmount:       req.TotalAmount,
          Currency:          req.Currency,
          DateTime:          req.DateTime,
          MerchantReference: req.MerchantReference,
          SecureHashType:    req.SecureHashType,
          SecureHash:        req.SecureHash,
          /* Card data stays client-side only */
          CardNumber:        cn.replace(/(.{4})/g,'$1 ').trim().replace(/.(?=.{4})/g,'*'),
          Environment:       ENV
        }, null, 2));

        /* Simulate Moamalat processing delay */
        await new Promise(function(r){ setTimeout(r, 1800); });

        /* Sandbox approval logic: test cards approved, others declined */
        var approved = cn.startsWith('4111111') || cn.startsWith('5500000');
        showResult(approved, txnRef, amt);

      } catch(err) {
        console.error('[Dawerli] SecureHash computation failed:', err);
        alert('خطأ في حساب SecureHash. تحقق من أن المتصفح يدعم WebCrypto API.');
      } finally {
        btn.disabled = false;
        $('paySpinner').style.display = 'none';
        $('payIcon').style.display    = '';
        $('payText').textContent      = 'إتمام الدفع (Sandbox)';
      }
    });

    /* ── Result modal ───────────────────────────────────────────────── */
    function showResult(success, txnRef, amt) {
      var icon = $('resultIcon'), iconI = $('resultIconI');
      if (success) {
        icon.className  = 'result-icon s';
        iconI.className = 'fas fa-check-circle';
        $('resultTitle').textContent = '✅ تمت العملية بنجاح!';
        $('resultMsg').textContent   = 'تم استلام دفعتك بقيمة ' + amt + ' د.ل عبر Moamalat (Sandbox). سيتواصل معك فريق دورلي للتأكيد.';
        $('resultBtn').textContent   = 'العودة للرئيسية';
        $('resultBtn').href          = '/';
      } else {
        icon.className  = 'result-icon f';
        iconI.className = 'fas fa-times-circle';
        $('resultTitle').textContent = '❌ لم تُكتمل العملية';
        $('resultMsg').textContent   = 'البطاقة مرفوضة في بيئة الاختبار. استخدم الأرقام التجريبية في لوحة الملخص.';
        $('resultBtn').textContent   = 'إعادة المحاولة';
        $('resultBtn').onclick       = function(){ $('resultOverlay').classList.remove('show'); return false; };
      }
      $('resultRef').textContent = txnRef;
      $('resultOverlay').classList.add('show');
    }

    $('resultOverlay').addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('show');
    });

  })();
  </script>

</Layout>
