---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="دورلي — بوابة الدفع التجريبية"
  description="صفحة دفع تجريبية Sandbox لمنصة دورلي. لن يتم إجراء أي خصم مالي حقيقي."
  noindex={true}
>
  <script is:inline>document.documentElement.dataset.page = 'checkout';</script>

  <style>
    /* ── Sandbox Banner ─────────────────────────────────────────────── */
    .sandbox-banner {
      position: sticky;
      top: 0;
      z-index: 1002;
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: #1c1917;
      text-align: center;
      padding: 0.75rem 1.2rem;
      font-size: 0.95rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      box-shadow: 0 2px 12px rgba(245,158,11,0.5);
    }
    .sandbox-banner i { font-size: 1.1rem; }
    .sandbox-badge {
      background: #1c1917;
      color: #fbbf24;
      padding: 0.15rem 0.6rem;
      border-radius: 6px;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      margin-right: 0.4rem;
    }

    /* ── Checkout Layout ────────────────────────────────────────────── */
    .checkout-wrapper {
      max-width: 820px;
      margin: 2rem auto;
      padding: 0 1rem 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      align-items: start;
    }
    @media (max-width: 700px) {
      .checkout-wrapper { grid-template-columns: 1fr; }
    }

    /* ── Order Summary ──────────────────────────────────────────────── */
    .order-summary {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius-lg);
      padding: 1.8rem;
      backdrop-filter: blur(10px);
    }
    .order-summary h2 {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--white);
      margin-bottom: 1.4rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .order-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.7rem 0;
      border-bottom: 1px solid var(--glass-border);
      font-size: 0.9rem;
      color: var(--text-muted);
    }
    .order-line:last-child { border-bottom: none; }
    .order-line .label { color: var(--text-muted); }
    .order-line .value { color: var(--text-main); font-weight: 600; }
    .order-total {
      margin-top: 1rem;
      padding: 1rem;
      background: rgba(79,70,229,0.1);
      border: 1px solid var(--primary);
      border-radius: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .order-total .t-label { font-weight: 700; color: var(--white); }
    .order-total .t-amount {
      font-size: 1.5rem;
      font-weight: 900;
      background: linear-gradient(135deg, var(--primary-light), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .moamalat-badge {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.2rem;
      padding: 0.8rem;
      background: rgba(16,185,129,0.08);
      border: 1px solid rgba(16,185,129,0.25);
      border-radius: 10px;
      font-size: 0.8rem;
      color: #6ee7b7;
    }
    .moamalat-badge i { font-size: 1rem; color: #10b981; }

    /* ── Payment Form ───────────────────────────────────────────────── */
    .payment-form-card {
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: var(--border-radius-lg);
      padding: 1.8rem;
      backdrop-filter: blur(10px);
    }
    .payment-form-card h2 {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--white);
      margin-bottom: 1.4rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .form-group { margin-bottom: 1.1rem; }
    .form-group label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }
    .form-group input, .form-group select {
      width: 100%;
      padding: 0.85rem 1rem;
      background: var(--bg-card);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      color: var(--text-main);
      font-family: 'Tajawal', sans-serif;
      font-size: 1rem;
      transition: border-color 0.2s;
      direction: ltr;
      text-align: left;
    }
    .form-group input:focus, .form-group select:focus {
      outline: none;
      border-color: var(--primary);
    }
    .form-row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }
    /* Card number visual formatting */
    .card-number-wrap { position: relative; }
    .card-type-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1.4rem;
      color: var(--text-muted);
      pointer-events: none;
    }
    #cardNumber { padding-left: 3rem; letter-spacing: 0.15em; }

    /* Submit button */
    .pay-btn {
      width: 100%;
      padding: 1.1rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white;
      border: none;
      border-radius: 14px;
      font-family: 'Tajawal', sans-serif;
      font-size: 1.1rem;
      font-weight: 800;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      transition: all 0.25s;
      margin-top: 0.5rem;
    }
    .pay-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(79,70,229,0.4); }
    .pay-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .pay-btn .spinner {
      width: 20px; height: 20px;
      border: 3px solid rgba(255,255,255,0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .secure-note {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      justify-content: center;
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 0.8rem;
    }
    .secure-note i { color: #10b981; }

    /* ── Success Modal ──────────────────────────────────────────────── */
    .result-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(5,5,5,0.92);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }
    .result-overlay.show { display: flex; }
    .result-modal {
      background: var(--bg-card);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      text-align: center;
      max-width: 420px;
      width: 100%;
      animation: popIn 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes popIn { from{opacity:0;transform:scale(0.85)} to{opacity:1;transform:scale(1)} }
    .result-icon {
      width: 72px; height: 72px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin: 0 auto 1.2rem;
    }
    .result-icon.success { background: rgba(16,185,129,0.2); color: #10b981; border: 2px solid #10b981; }
    .result-icon.fail    { background: rgba(239,68,68,0.2);  color: #ef4444; border: 2px solid #ef4444; }
    .result-modal h3 { font-size: 1.3rem; font-weight: 800; color: var(--white); margin-bottom: 0.5rem; }
    .result-modal p  { color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1.5rem; }
    .result-ref {
      display: inline-block;
      background: rgba(79,70,229,0.15);
      border: 1px solid var(--primary);
      border-radius: 8px;
      padding: 0.4rem 1rem;
      font-size: 0.85rem;
      color: var(--accent-light);
      font-family: monospace;
      margin-bottom: 1.5rem;
    }
    .result-btn {
      display: inline-block;
      padding: 0.85rem 2rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: white;
      border: none;
      border-radius: 50px;
      font-family: 'Tajawal', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }
    .result-btn:hover { transform: translateY(-2px); }

    /* ── Sandbox tech note ──────────────────────────────────────────── */
    .tech-note {
      max-width: 820px;
      margin: 0 auto 2rem;
      padding: 1rem 1.5rem;
      background: rgba(239,68,68,0.07);
      border: 1px solid rgba(239,68,68,0.25);
      border-radius: 12px;
      font-size: 0.82rem;
      color: #fca5a5;
      display: flex;
      gap: 0.8rem;
      align-items: flex-start;
    }
    .tech-note i { flex-shrink: 0; margin-top: 0.1rem; color: #ef4444; }
    @media (max-width: 480px) {
      .sandbox-banner { font-size: 0.82rem; flex-wrap: wrap; }
    }
  </style>

  <!-- ══════════════════════════════════════════════════════════════
       ⚠️  SANDBOX WARNING BANNER (ANTI-FRAUD RULE — ALWAYS VISIBLE)
       ══════════════════════════════════════════════════════════════ -->
  <div class="sandbox-banner" role="alert" aria-live="assertive">
    <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
    <span class="sandbox-badge">SANDBOX</span>
    <strong>بيئة تجريبية (Sandbox Mode)</strong>&nbsp;—&nbsp;لن يتم إجراء أي خصم مالي حقيقي
  </div>

  <!-- Page Title -->
  <section class="page-hero" style="padding-bottom:1.5rem;">
    <div class="hero-content">
      <h1 style="font-size:1.8rem;">
        <i class="fas fa-credit-card" style="color:var(--accent);" aria-hidden="true"></i>
        بوابة الدفع الإلكتروني
        <span style="font-size:0.75rem;background:rgba(245,158,11,0.2);color:#fbbf24;padding:0.2rem 0.7rem;border-radius:20px;vertical-align:middle;margin-right:0.5rem;">SANDBOX</span>
      </h1>
      <p style="font-size:0.95rem;">مدعومة بتقنية معاملات (Moamalat) — بيئة اختبار آمنة ومعتمدة</p>
    </div>
  </section>

  <!-- Tech disclaimer -->
  <div class="tech-note">
    <i class="fas fa-info-circle"></i>
    <span>
      هذه الصفحة تعمل في وضع <strong>Sandbox</strong> وتستخدم بيانات اختبار من Moamalat.
      في بيئة الإنتاج يتم حساب SecureHash (SHA-512) على الخادم لمنع التلاعب.
      لا تُدخل بيانات بطاقة حقيقية — استخدم أرقام البطاقات التجريبية أدناه.
    </span>
  </div>

  <!-- Main Grid -->
  <div class="checkout-wrapper">

    <!-- ① Order Summary -->
    <aside class="order-summary" aria-label="ملخص الطلب">
      <h2><i class="fas fa-receipt" aria-hidden="true"></i> ملخص الطلب</h2>

      <div class="order-line">
        <span class="label">رقم الطلب</span>
        <span class="value" id="sumRef">DW-2026-—</span>
      </div>
      <div class="order-line">
        <span class="label">نوع الخدمة</span>
        <span class="value" id="sumCat">توصيل عادي</span>
      </div>
      <div class="order-line">
        <span class="label">المدينة</span>
        <span class="value" id="sumCity">—</span>
      </div>
      <div class="order-line">
        <span class="label">رسوم الخدمة</span>
        <span class="value" id="sumFee">20 د.ل</span>
      </div>
      <div class="order-line">
        <span class="label">المنتج / الخدمة</span>
        <span class="value" id="sumProduct" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">—</span>
      </div>

      <div class="order-total">
        <span class="t-label">المجموع الكلي</span>
        <span class="t-amount" id="sumTotal">20 د.ل</span>
      </div>

      <!-- Moamalat sandbox cards reference -->
      <div class="moamalat-badge" style="flex-direction:column;align-items:flex-start;gap:0.4rem;margin-top:1.4rem;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <i class="fas fa-credit-card"></i>
          <strong>بطاقات الاختبار (Sandbox)</strong>
        </div>
        <div style="font-family:monospace;font-size:0.78rem;line-height:1.8;color:var(--text-muted);padding-right:0.3rem;">
          ✅ VISA:&nbsp;&nbsp;&nbsp;&nbsp;4111 1111 1111 1111<br>
          ✅ Master: 5500 0000 0000 0004<br>
          📅 Expiry: أي تاريخ مستقبلي<br>
          🔒 CVV:&nbsp;&nbsp;&nbsp;أي 3 أرقام
        </div>
      </div>

      <!-- Powered by -->
      <div style="margin-top:1.5rem;text-align:center;padding-top:1rem;border-top:1px solid var(--glass-border);">
        <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.4rem;">مدعومة بتقنية</div>
        <div style="font-size:1rem;font-weight:800;color:var(--accent-light);letter-spacing:0.05em;">معاملات · Moamalat</div>
        <div style="font-size:0.7rem;color:var(--text-muted);margin-top:0.2rem;">Sandbox Environment v2.0</div>
      </div>
    </aside>

    <!-- ② Payment Form -->
    <section class="payment-form-card" aria-label="نموذج الدفع">
      <h2><i class="fas fa-lock" aria-hidden="true"></i> بيانات الدفع</h2>

      <form id="paymentForm" autocomplete="off" novalidate>

        <!-- Cardholder name -->
        <div class="form-group">
          <label for="cardName"><i class="fas fa-user"></i> اسم حامل البطاقة</label>
          <input type="text" id="cardName" placeholder="FULL NAME (as on card)"
                 autocomplete="cc-name" inputmode="text" required>
        </div>

        <!-- Card number -->
        <div class="form-group">
          <label for="cardNumber"><i class="fas fa-credit-card"></i> رقم البطاقة</label>
          <div class="card-number-wrap">
            <i class="fas fa-credit-card card-type-icon" id="cardTypeIcon"></i>
            <input type="text" id="cardNumber" placeholder="0000  0000  0000  0000"
                   inputmode="numeric" maxlength="19" autocomplete="cc-number" required>
          </div>
        </div>

        <!-- Expiry + CVV -->
        <div class="form-row-2">
          <div class="form-group">
            <label for="expiry"><i class="fas fa-calendar-alt"></i> تاريخ الانتهاء</label>
            <input type="text" id="expiry" placeholder="MM / YY"
                   inputmode="numeric" maxlength="7" autocomplete="cc-exp" required>
          </div>
          <div class="form-group">
            <label for="cvv"><i class="fas fa-shield-alt"></i> رمز CVV</label>
            <input type="text" id="cvv" placeholder="•••"
                   inputmode="numeric" maxlength="4" autocomplete="cc-csc" required>
          </div>
        </div>

        <!-- Amount (pre-filled, editable in sandbox) -->
        <div class="form-group">
          <label for="amount"><i class="fas fa-money-bill-wave"></i> المبلغ (دينار ليبي)</label>
          <input type="number" id="amount" min="1" max="99999"
                 placeholder="20" value="20" required>
        </div>

        <!-- Submit -->
        <button type="submit" class="pay-btn" id="payBtn">
          <span class="spinner" id="paySpinner"></span>
          <i class="fas fa-lock" id="payIcon"></i>
          <span id="payText">إتمام الدفع (Sandbox)</span>
        </button>

        <p class="secure-note">
          <i class="fas fa-shield-alt"></i>
          مشفّر بـ TLS 1.3 · SHA-512 SecureHash · PCI-DSS Compliant (Sandbox)
        </p>
      </form>
    </section>

  </div>

  <!-- ══════════════════════════════════════════════════════════════
       SUCCESS / FAILURE MODAL
       ══════════════════════════════════════════════════════════════ -->
  <div class="result-overlay" id="resultOverlay" role="dialog" aria-modal="true">
    <div class="result-modal">
      <div class="result-icon success" id="resultIcon">
        <i class="fas fa-check-circle" id="resultIconI"></i>
      </div>
      <h3 id="resultTitle">تمت العملية بنجاح!</h3>
      <p id="resultMsg">تم إرسال الدفع إلى بوابة Moamalat (Sandbox). سيتواصل معك فريق دورلي قريباً.</p>
      <div class="result-ref" id="resultRef">TXN-SANDBOX-0000</div>
      <br>
      <a href="/request" class="result-btn" id="resultBtn">العودة للطلبات</a>
    </div>
  </div>

  <script is:inline>
  (function () {
    'use strict';

    /* ── Read URL params → populate order summary ───────────────────── */
    var p = new URLSearchParams(window.location.search);
    var orderRef = p.get('ref')  || ('DW-2026-' + (Math.floor(Math.random()*9000)+1000));
    var cat      = p.get('cat')  || 'توصيل عادي';
    var city     = p.get('city') || '—';
    var product  = p.get('desc') || '—';
    var fee      = parseInt(p.get('fee') || '20', 10);

    var $ = function(id){ return document.getElementById(id); };
    $('sumRef').textContent     = orderRef;
    $('sumCat').textContent     = cat;
    $('sumCity').textContent    = city;
    $('sumFee').textContent     = fee + ' د.ل';
    $('sumProduct').textContent = product.length > 30 ? product.slice(0,30)+'…' : product;
    $('sumTotal').textContent   = fee + ' د.ل';
    $('amount').value           = fee;

    /* ── Card number auto-format (XXXX XXXX XXXX XXXX) ─────────────── */
    $('cardNumber').addEventListener('input', function(e){
      var v = e.target.value.replace(/\D/g,'').slice(0,16);
      e.target.value = v.replace(/(.{4})/g,'$1  ').trim();
      // Detect card type
      var icon = $('cardTypeIcon');
      if(/^4/.test(v))      { icon.className='fab fa-cc-visa card-type-icon'; icon.style.color='#1a1f71'; }
      else if(/^5/.test(v)) { icon.className='fab fa-cc-mastercard card-type-icon'; icon.style.color='#eb001b'; }
      else                   { icon.className='fas fa-credit-card card-type-icon'; icon.style.color=''; }
    });

    /* ── Expiry auto-format (MM / YY) ──────────────────────────────── */
    $('expiry').addEventListener('input', function(e){
      var v = e.target.value.replace(/\D/g,'').slice(0,4);
      if(v.length >= 3) e.target.value = v.slice(0,2) + ' / ' + v.slice(2);
      else e.target.value = v;
    });

    /* ── CVV: numbers only ─────────────────────────────────────────── */
    $('cvv').addEventListener('input', function(e){
      e.target.value = e.target.value.replace(/\D/g,'').slice(0,4);
    });

    /* ── Generate TransactionRef ────────────────────────────────────── */
    function genTxnRef(){
      return 'TXN-SB-' + Date.now().toString(36).toUpperCase() + '-' +
             Math.random().toString(36).substr(2,4).toUpperCase();
    }

    /* ── Build Moamalat request params (Sandbox field structure) ────── */
    function buildMoamalatParams(txnRef, amount){
      var now  = new Date();
      var pad  = function(n){ return String(n).padStart(2,'0'); };
      var dt   = now.getFullYear() + pad(now.getMonth()+1) + pad(now.getDate()) +
                 pad(now.getHours()) + pad(now.getMinutes()) + pad(now.getSeconds());
      return {
        MerchantID:     'DAWERLI_SANDBOX_001',
        TerminalID:     'TID_SANDBOX_001',
        DateTime:       dt,
        TotalAmount:    String(amount * 1000),   // Moamalat uses smallest unit (milliemes)
        TaxAmount:      '0',
        TransactionRef: txnRef,
        OrderID:        orderRef,
        SecureHashType: 'SHA512',
        /* SecureHash would be computed server-side in production.
           Here we show the field structure only.                   */
        SecureHash:     'SANDBOX_HASH_DEMO'
      };
    }

    /* ── Form submit handler ────────────────────────────────────────── */
    $('paymentForm').addEventListener('submit', function(e){
      e.preventDefault();

      var cardNum  = $('cardNumber').value.replace(/\s/g,'');
      var expiry   = $('expiry').value;
      var cvv      = $('cvv').value;
      var name     = $('cardName').value.trim();
      var amount   = parseInt($('amount').value, 10) || 20;

      /* Basic validation */
      if(cardNum.length < 13 || !expiry || cvv.length < 3 || !name){
        alert('يرجى إدخال بيانات البطاقة كاملةً (استخدم بطاقة الاختبار المذكورة)');
        return;
      }

      /* Loading state */
      var btn = $('payBtn');
      btn.disabled = true;
      $('paySpinner').style.display = 'block';
      $('payIcon').style.display    = 'none';
      $('payText').textContent      = 'جارٍ المعالجة...';

      /* Build Moamalat params (for transparency/debug) */
      var txnRef = genTxnRef();
      var params = buildMoamalatParams(txnRef, amount);
      console.info('[Dawerli Sandbox] Moamalat params:', JSON.stringify(params, null, 2));

      /* Simulate Moamalat processing delay (1.8s) then show result */
      setTimeout(function(){
        btn.disabled = false;
        $('paySpinner').style.display = 'none';
        $('payIcon').style.display    = '';
        $('payText').textContent      = 'إتمام الدفع (Sandbox)';

        /* Sandbox: always approve for test cards, decline others */
        var approved = cardNum.startsWith('4111111') || cardNum.startsWith('5500000');
        showResult(approved, txnRef, amount);
      }, 1800);
    });

    /* ── Show result modal ──────────────────────────────────────────── */
    function showResult(success, txnRef, amount){
      var icon  = $('resultIcon');
      var iconI = $('resultIconI');
      if(success){
        icon.className  = 'result-icon success';
        iconI.className = 'fas fa-check-circle';
        $('resultTitle').textContent = '✅ تمت العملية بنجاح!';
        $('resultMsg').textContent   = 'تم استلام دفعتك بقيمة ' + amount + ' د.ل عبر بوابة Moamalat (Sandbox). سيتواصل معك فريق دورلي قريباً لتأكيد الطلب.';
        $('resultBtn').textContent   = 'العودة للرئيسية';
        $('resultBtn').href          = '/';
      } else {
        icon.className  = 'result-icon fail';
        iconI.className = 'fas fa-times-circle';
        $('resultTitle').textContent = '❌ لم تُكتمل العملية';
        $('resultMsg').textContent   = 'البطاقة غير مقبولة في بيئة الاختبار. يرجى استخدام أرقام البطاقات التجريبية المذكورة في ملخص الطلب.';
        $('resultBtn').textContent   = 'إعادة المحاولة';
        $('resultBtn').onclick       = function(){ $('resultOverlay').classList.remove('show'); };
      }
      $('resultRef').textContent = txnRef;
      $('resultOverlay').classList.add('show');
    }

    /* ── Close overlay on backdrop click ───────────────────────────── */
    $('resultOverlay').addEventListener('click', function(e){
      if(e.target === this) this.classList.remove('show');
    });

  })();
  </script>

</Layout>
