---
import Layout from '../layouts/Layout.astro';
---

<Layout title="دورلي - اطلب الآن" description="ارسل طلبك الآن وسنقوم بتوفيره لك فوراً">
  <section class="page-hero">
    <div class="hero-content reveal">
      <h1>ارسل طلبك الآن</h1>
      <p>بضع خطوات بسيطة وسنتولى نحن بقية المهمة</p>
    </div>
  </section>

  <section class="request-form-section">
    <div class="container">
      <div class="request-container reveal">
        <form id="orderForm" class="order-form">
          <div class="form-group">
            <label for="name"><i class="fas fa-user"></i> الاسم الكريم</label>
            <input type="text" id="name" name="name" required placeholder="مثلاً: محمد الفيتوري">
          </div>

          <div class="form-group">
            <label for="phone"><i class="fas fa-phone"></i> رقم الهاتف</label>
            <input type="tel" id="phone" name="phone" required placeholder="09XXXXXXXX">
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="city"><i class="fas fa-map-marker-alt"></i> مدينة التسليم</label>
              <select id="city" name="city" required>
                <option value="" disabled selected>اختر المدينة</option>
                <option value="إجدابيا">إجدابيا</option>
                <option value="جالو">جالو</option>
                <option value="أوجلة">أوجلة</option>
                <option value="أجخرة">أجخرة</option>
                <option value="بنغازي">بنغازي</option>
                <option value="طرابلس">طرابلس</option>
                <option value="الكفرة">الكفرة</option>
                <option value="طبرق">طبرق</option>
                <option value="البيضاء">البيضاء</option>
                <option value="مصراتة">مصراتة</option>
              </select>
            </div>

            <div class="form-group">
              <label for="category"><i class="fas fa-tag"></i> نوع الطلب</label>
              <select id="category" name="category" required>
                <option value="" disabled selected>اختر الفئة</option>
                <option value="قطع غيار سيارات">قطع غيار سيارات</option>
                <option value="قطع غيار شاحنات">قطع غيار شاحنات</option>
                <option value="مواد غذائية وحلويات">مواد غذائية وحلويات</option>
                <option value="توصيل مستندات وأوراق">توصيل مستندات وأوراق</option>
                <option value="أخرى">طلب خاص آخر</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="product"><i class="fas fa-pen"></i> تفاصيل الطلب</label>
            <textarea id="product" name="product" required placeholder="اكتب بالتفصيل ما الذي تبحث عنه..."></textarea>
          </div>

          <button type="submit" class="submit-btn">إرسال عبر واتساب <i class="fab fa-whatsapp"></i></button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    // التقاط الفئة تلقائياً
    document.addEventListener('DOMContentLoaded', () => {
      const cat = new URLSearchParams(window.location.search).get('cat');
      if (cat) {
        const select = document.getElementById('category');
        for(let i=0; i<select.options.length; i++) {
          if(select.options[i].value === cat) { select.selectedIndex = i; break; }
        }
      }
    });

    // إرسال للواتساب بنفس رقمك المعتمد
    document.getElementById('orderForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const name = document.getElementById('name').value;
      const phone = document.getElementById('phone').value;
      const city = document.getElementById('city').value;
      const category = document.getElementById('category').value;
      const product = document.getElementById('product').value;
      
      const msg = `*طلب جديد من دورلي*%0A👤 الاسم: ${name}%0A📞 الهاتف: ${phone}%0A📍 المدينة: ${city}%0A🏷️ الفئة: ${category}%0A📝 التفاصيل: ${product}`;
      window.open(`https://wa.me/218946507954?text=${msg}`, '_blank');
    });
  </script>
</Layout>
