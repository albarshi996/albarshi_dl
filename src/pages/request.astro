---
import Layout from '../layouts/Layout.astro';
---

<Layout title="دورلي - اطلب الآن عبر واتساب" description="نموذج طلب دورلي - اطلب أي منتج أو خدمة من أي مدينة في ليبيا. لا يتم تسجيل دخول، يتم تحويلك مباشرة لمحادثة واتساب.">
  <script is:inline>document.documentElement.dataset.page = 'request';</script>

  <!-- Schema.org markup يوضح لجوجل أن هذا نموذج طلب وليس تسجيل دخول -->
  <script type="application/ld+json" data-i18n-jsonld set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "OrderAction",
    "name": "طلب توصيل عبر دورلي",
    "description": "نموذج طلب توصيل بضائع — يتم إرسال البيانات مباشرة إلى رقم واتساب الخدمة، ولا يطلب الموقع كلمات مرور أو بيانات اعتماد",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://wa.me/218946507954",
      "actionPlatform": ["https://schema.org/MobileWebPlatform", "https://schema.org/DesktopWebPlatform"]
    },
    "potentialAction": {
      "@type": "CommunicateAction",
      "recipient": {
        "@type": "ContactPoint",
        "telephone": "+218946507954",
        "contactType": "customer service"
      }
    }
  })} />

  <style>
    .whatsapp-notice { max-width:680px; margin:1.5rem auto 0; padding:1.2rem 1.4rem; background:linear-gradient(135deg, rgba(37,211,102,0.18), rgba(37,211,102,0.08)); border:2px solid #25D366; border-radius:14px; display:flex; align-items:center; gap:1rem; }
    .whatsapp-notice .wn-icon { font-size:2.2rem; color:#25D366; flex-shrink:0; }
    .whatsapp-notice .wn-text { color:var(--text-main); font-size:0.95rem; line-height:1.7; }
    .whatsapp-notice .wn-text strong { color:#25D366; display:block; margin-bottom:0.3rem; font-size:1.05rem; }
    .whatsapp-notice .wn-text small { display:block; margin-top:0.4rem; color:var(--text-muted); font-size:0.8rem; }

    .steps-bar { display:flex; justify-content:center; align-items:center; gap:0.5rem; padding:1.5rem 1rem; margin-bottom:1rem; }
    .step { display:flex; flex-direction:column; align-items:center; gap:0.3rem; opacity:0.4; transition:all 0.3s; }
    .step.active { opacity:1; }
    .step.done { opacity:1; }
    .step-circle { width:36px; height:36px; border-radius:50%; background:var(--glass-bg); border:2px solid var(--glass-border); display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; color:var(--text-muted); }
    .step.active .step-circle { background:var(--primary); border-color:var(--primary); color:white; }
    .step.done .step-circle { background:#10b981; border-color:#10b981; color:white; }
    .step-label { font-size:0.7rem; color:var(--text-muted); }
    .step.active .step-label { color:var(--accent-light); }
    .step-line { width:40px; height:2px; background:var(--glass-border); margin-bottom:1.2rem; }
    .quantity-group { display:flex; align-items:center; gap:0.8rem; background:var(--glass-bg); border:1px solid var(--glass-border); border-radius:var(--border-radius); padding:0.5rem 1rem; }
    .qty-btn { width:36px; height:36px; border-radius:50%; border:1px solid var(--glass-border); background:var(--bg-card); color:var(--text-main); font-size:1.2rem; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.2s; }
    .qty-btn:hover { background:var(--primary); border-color:var(--primary); }
    .qty-display { flex:1; text-align:center; font-size:1.3rem; font-weight:700; color:var(--white); }
    .urgency-options { display:grid; grid-template-columns:repeat(3,1fr); gap:0.6rem; }
    .urgency-btn { padding:0.7rem 0.5rem; border-radius:12px; border:1px solid var(--glass-border); background:var(--bg-card); color:var(--text-muted); font-family:'Tajawal',sans-serif; font-size:0.8rem; cursor:pointer; text-align:center; transition:all 0.2s; }
    .urgency-btn i { display:block; font-size:1.2rem; margin-bottom:0.3rem; }
    .urgency-btn.sel-normal { background:rgba(16,185,129,0.15); border-color:#10b981; color:#10b981; }
    .urgency-btn.sel-medium { background:rgba(245,158,11,0.15); border-color:#f59e0b; color:#f59e0b; }
    .urgency-btn.sel-urgent { background:rgba(239,68,68,0.15); border-color:#ef4444; color:#ef4444; }
    .success-overlay { display:none; position:fixed; inset:0; background:rgba(5,5,5,0.96); z-index:9999; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:2rem; }
    .success-overlay.show { display:flex; animation:fadeIn 0.4s ease; }
    @keyframes fadeIn { from{opacity:0;transform:scale(0.9)} to{opacity:1;transform:scale(1)} }
    .form-container { max-width:680px; margin:0 auto; padding:1.5rem; background:var(--glass-bg); border:1px solid var(--glass-border); border-radius:18px; }
    .form-header { text-align:center; margin-bottom:1.5rem; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem; }
    @media (max-width:640px) { .form-row { grid-template-columns:1fr; } }
    .form-group { margin-bottom:1rem; }
    .form-group.full-width { grid-column:1/-1; }
    .form-group label { display:flex; align-items:center; gap:0.5rem; margin-bottom:0.6rem; font-weight:600; color:var(--text-main); }
    .form-group input, .form-group select, .form-group textarea { width:100%; padding:0.8rem 1rem; background:var(--bg-card); border:1px solid var(--glass-border); border-radius:12px; color:var(--text-main); font-family:'Tajawal',sans-serif; font-size:1rem; }
    .form-group textarea { min-height:100px; resize:vertical; }
    .badge-required { background:rgba(239,68,68,0.15); color:#ef4444; padding:0.15rem 0.5rem; border-radius:8px; font-size:0.7rem; margin-right:auto; }
    .submit-btn { width:100%; padding:1rem; background:linear-gradient(135deg, #25D366, #128C7E); color:white; border:none; border-radius:14px; font-family:'Tajawal',sans-serif; font-size:1.1rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.6rem; transition:all 0.2s; }
    .submit-btn:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(37,211,102,0.4); }
    .form-note { text-align:center; margin-top:0.8rem; font-size:0.85rem; color:var(--text-muted); }
    .form-note a { color:var(--accent-light); text-decoration:underline; }
  </style>

  <div class="whatsapp-notice" role="region" aria-label="تنبيه: نموذج طلب توصيل، ليس صفحة تسجيل دخول">
    <div class="wn-icon"><i class="fab fa-whatsapp"></i></div>
    <div class="wn-text">
      <strong><span data-i18n="noticeTitle">هذا نموذج طلب توصيل — وليس صفحة تسجيل دخول</span></strong>
      <span data-i18n="noticeDesc">عند الإرسال سيتم تحويلك مباشرة لمحادثة <strong style="display:inline">واتساب</strong> مع فريق دورلي. لا نطلب كلمات مرور أو بيانات بنكية.</span>
      <small><span data-i18n="noticeLinks">للاطلاع على معلومات الخصوصية: <a href="/privacy/">سياسة الخصوصية</a> | <a href="/terms/">الشروط</a></span></small>
    </div>
  </div>

  <div class="steps-bar" aria-hidden="true">
    <div class="step active" id="step1"><div class="step-circle">1</div><div class="step-label"><span data-i18n="step1">بياناتك</span></div></div>
    <div class="step-line"></div>
    <div class="step" id="step2"><div class="step-circle">2</div><div class="step-label"><span data-i18n="step2">الطلب</span></div></div>
    <div class="step-line"></div>
    <div class="step" id="step3"><div class="step-circle">3</div><div class="step-label"><span data-i18n="step3">الإرسال</span></div></div>
  </div>

  <section class="request-form-section">
    <div class="container reveal">
      <div class="form-container">
        <div class="form-header">
          <h2><i class="fas fa-shopping-cart"></i> <span data-i18n="orderDetailsTitle">تفاصيل الطلب</span></h2>
          <p><span data-i18n="orderDetailsDesc">يرجى إدخال معلومات الطلب لتحويلك لمحادثة واتساب جاهزة</span></p>
        </div>

        <form id="orderForm" class="request-form" method="GET" data-wa-form role="form" aria-label="نموذج طلب توصيل عبر واتساب — لا يتم تخزين بيانات أو تسجيل دخول">
          <div class="form-row">
            <div class="form-group">
              <label for="name"><i class="fas fa-user"></i> <span data-i18n="labelName">الاسم الكريم</span> <span class="badge-required" data-i18n="required">مطلوب</span></label>
              <input type="text" id="name" name="customer_name" autocomplete="name" placeholder="اكتب اسمك الثلاثي" data-i18n-placeholder="placeholderName" required aria-describedby="name-help">
              <span id="name-help" class="visually-hidden">اسمك سيُستخدم في رسالة الواتساب فقط</span>
            </div>
            <div class="form-group">
              <label for="phone"><i class="fas fa-phone"></i> <span data-i18n="labelPhone">رقم الواتساب</span> <span class="badge-required" data-i18n="required">مطلوب</span></label>
              <input type="tel" id="phone" name="customer_phone" inputmode="numeric" pattern="^(09[0-9]{8})$" maxlength="10" autocomplete="tel-national" placeholder="مثال: 0911234567" data-i18n-placeholder="placeholderPhoneExample" required aria-describedby="phone-help">
              <span id="phone-help" class="visually-hidden">رقم هاتفك للتواصل عبر واتساب</span>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group full-width">
              <label for="city"><i class="fas fa-map-marker-alt"></i> <span data-i18n="labelCity">مدينة التسليم</span> <span class="badge-required" data-i18n="required">مطلوب</span></label>
              <select id="city" name="delivery_city" autocomplete="address-level2" required>
                <option value="" disabled selected data-i18n="selectCityPlaceholder">اختر مدينتك...</option>
                <option value="طرابلس" data-i18n="city_tripoli">طرابلس</option>
                <option value="بنغازي" data-i18n="city_benghazi">بنغازي</option>
                <option value="مصراتة" data-i18n="city_misrata">مصراتة</option>
                <option value="الزاوية" data-i18n="city_alzawiya">الزاوية</option>
                <option value="زليتن" data-i18n="city_zliten">زليتن</option>
                <option value="البيضاء" data-i18n="city_albayda">البيضاء</option>
                <option value="الخمس" data-i18n="city_alkhoms">الخمس</option>
                <option value="سبها" data-i18n="city_sabha">سبها</option>
                <option value="درنة" data-i18n="city_derna">درنة</option>
                <option value="سرت" data-i18n="city_sirte">سرت</option>
                <option value="جالو" data-i18n="city_jalu">جالو</option>
                <option value="أوجلة" data-i18n="city_awjila">أوجلة</option>
                <option value="إجخرة" data-i18n="city_ijkhara">إجخرة</option>
                <option value="أخرى" data-i18n="city_other">مدينة أخرى (وضّحها في التفاصيل)</option>
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group full-width">
              <label for="category"><i class="fas fa-tags"></i> <span data-i18n="labelCategory">نوع الطلب</span> <span class="badge-required" data-i18n="required">مطلوب</span></label>
              <select id="category" name="order_category" required>
                <option value="" disabled selected data-i18n="selectCategoryPlaceholder">اختر نوع الطلب...</option>
                <option value="قطع غيار سيارات" data-i18n="catCarParts">🚗 قطع غيار سيارات</option>
                <option value="قطع غيار شاحنات" data-i18n="catTruckParts">🚛 قطع غيار شاحنات</option>
                <option value="مواد غذائية وحلويات" data-i18n="catFood">🍔 مواد غذائية وحلويات</option>
                <option value="أوراق ومستندات" data-i18n="catDocs">📄 أوراق ومستندات</option>
                <option value="مستلزمات أفراح" data-i18n="catWedding">💍 مستلزمات أفراح</option>
                <option value="ملابس وأزياء" data-i18n="catCustom">👗 ملابس وأزياء</option>
                <option value="تجميل ونظافة" data-i18n="catBeauty">💄 تجميل ونظافة</option>
                <option value="مواد بناء وصيانة" data-i18n="catConstruction">🏗️ مواد بناء وصيانة</option>
                <option value="إلكترونيات" data-i18n="catCustom">📱 إلكترونيات</option>
                <option value="أخرى" data-i18n="city_other">📦 أخرى</option>
              </select>
            </div>
          </div>

          <div class="form-group full-width">
            <label><i class="fas fa-layer-group"></i> <span data-i18n="labelQuantity">الكمية المطلوبة</span></label>
            <div class="quantity-group">
              <button type="button" class="qty-btn" id="qtyMinus" aria-label="إنقاص الكمية">−</button>
              <div class="qty-display" id="qtyDisplay">1</div>
              <button type="button" class="qty-btn" id="qtyPlus" aria-label="زيادة الكمية">+</button>
              <input type="hidden" id="quantity" name="order_quantity" value="1">
            </div>
          </div>

          <div class="form-group full-width">
            <label><i class="fas fa-clock"></i> <span data-i18n="labelUrgency">درجة الاستعجال</span></label>
            <div class="urgency-options">
              <button type="button" class="urgency-btn sel-normal" data-urgency="عادي">
                <i class="fas fa-leaf"></i> <span data-i18n="urgencyNormal">عادي</span>
              </button>
              <button type="button" class="urgency-btn" data-urgency="متوسط">
                <i class="fas fa-bolt"></i> <span data-i18n="urgencyMedium">متوسط</span>
              </button>
              <button type="button" class="urgency-btn" data-urgency="عاجل">
                <i class="fas fa-fire"></i> <span data-i18n="urgencyUrgent">عاجل</span>
              </button>
            </div>
            <input type="hidden" id="urgency" name="order_urgency" value="عادي">
          </div>

          <div class="form-group full-width">
            <label for="product"><i class="fas fa-box-open"></i> <span data-i18n="labelDetails">تفاصيل طلبك</span> <span class="badge-required" data-i18n="required">مطلوب</span></label>
            <textarea id="product" name="order_details" placeholder="اكتب وصفاً دقيقاً للمنتج أو الخدمة (النوع، المواصفات، وأي تفاصيل هامة)..." required></textarea>
          </div>

          <div class="form-submit">
            <button type="submit" class="submit-btn" aria-label="فتح محادثة واتساب لإرسال الطلب">
              <i class="fab fa-whatsapp" style="font-size:1.4rem;"></i> <span data-i18n="submitSendWhatsapp">فتح محادثة واتساب وإرسال الطلب</span>
            </button>
            <p class="form-note">
              <i class="fas fa-shield-alt"></i> <span data-i18n="formNote">بياناتك تُرسل عبر تطبيق واتساب الرسمي فقط — لا تخزين، لا حسابات، لا كلمات مرور.</span>
              <br>
              <a href="/privacy/" data-i18n="linkPrivacy">اقرأ سياسة الخصوصية</a> · <a href="/terms/" data-i18n="linkTerms">الشروط والأحكام</a>
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    let qty = 1;
    document.getElementById('qtyPlus').onclick = () => { qty = Math.min(qty+1,99); document.getElementById('qtyDisplay').textContent = qty; document.getElementById('quantity').value = qty; };
    document.getElementById('qtyMinus').onclick = () => { qty = Math.max(qty-1,1); document.getElementById('qtyDisplay').textContent = qty; document.getElementById('quantity').value = qty; };

    document.querySelectorAll('.urgency-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.urgency-btn').forEach(b => b.className = 'urgency-btn');
        const val = btn.dataset.urgency;
        btn.classList.add(val==='عادي'?'sel-normal':val==='متوسط'?'sel-medium':'sel-urgent');
        document.getElementById('urgency').value = val;
      });
    });

    document.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const cat = urlParams.get('cat');
      if (cat) {
        const select = document.getElementById('category');
        for (let i = 0; i < select.options.length; i++) {
          if (select.options[i].value === cat) { select.selectedIndex = i; break; }
        }
      }
    });

    const fields = ['name','phone','city','category','product'];
    function updateSteps() {
      const v = f => document.getElementById(f).value.trim();
      const s1 = v('name') && v('phone');
      const s2 = s1 && v('city') && v('category') && v('product');
      document.getElementById('step1').className = 'step '+(s1?'done':'active');
      document.getElementById('step2').className = 'step '+(s2?'done':s1?'active':'');
      document.getElementById('step3').className = 'step '+(s2?'active':'');
    }
    fields.forEach(f => { document.getElementById(f).addEventListener('input', updateSteps); document.getElementById(f).addEventListener('change', updateSteps); });

    document.getElementById('orderForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const name = document.getElementById('name').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const city = document.getElementById('city').value;
      const category = document.getElementById('category').value;
      const product = document.getElementById('product').value.trim();
      const quantity = document.getElementById('quantity').value;
      const urgency = document.getElementById('urgency').value;

        if (!/^09[0-9]{8}$/.test(phone)) {
          alert(window.dawerli_i18n.getString('alertInvalidPhone') || 'الرجاء إدخال رقم هاتف ليبي صحيح (10 أرقام يبدأ بـ 09)');
          return;
        }

      const orderNum = 'DW-2026-' + String(Math.floor(Math.random()*9000)+1000);
      const get = (k) => (window.dawerli_i18n && window.dawerli_i18n.getString) ? window.dawerli_i18n.getString(k) || '' : '';
      const header = (category === (get('catCarParts') || 'قطع غيار سيارات')) ? (get('whatsapp_car_header') || '*طلب قطع غيار جديد - دورلي*') : (get('whatsapp_other_header_prefix') || '*طلب جديد*');

      let message = `${header}\n\n`;
      message += `🔖 ${get('wa_order_number_label') || 'رقم الطلب'}: ${orderNum}\n`;
      message += `👤 ${get('labelName') || 'الاسم'}: ${name}\n`;
      message += `📞 ${get('labelPhone') || 'الهاتف'}: ${phone}\n`;
      message += `📍 ${get('labelCity') || 'المدينة'}: ${city}\n`;
      message += `📦 ${get('labelCategory') || 'النوع'}: ${category}\n`;
      message += `🔢 ${get('labelQuantity') || 'الكمية'}: ${quantity}\n`;
      message += `⏱️ ${get('labelUrgency') || 'الاستعجال'}: ${urgency}\n`;
      message += `📝 ${get('labelDetails') || 'التفاصيل'}: ${product}`;

      if(category === (get('catCarParts') || 'قطع غيار سيارات')){
        const note = get('whatsapp_attach_note');
        if(note) message += `\n\n${note}`;
      }

      const base = (window.dawerli_i18n && window.dawerli_i18n.getWhatsAppBase) ? window.dawerli_i18n.getWhatsAppBase() : ((window.dawerli_i18n && window.dawerli_i18n.getPhoneInfo) ? window.dawerli_i18n.getPhoneInfo().waBase : null);
      if(!base){
        alert(get('alertNoContact') || 'رقم خدمة الواتساب غير مكوّن حالياً. الرجاء التواصل عبر الرابط الموجود في الصفحة.');
        return;
      }
      const whatsappUrl = `${base}?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank', 'noopener,noreferrer');
    });
  </script>
</Layout>
