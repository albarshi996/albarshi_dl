---
import Layout from '../layouts/Layout.astro';
---

<Layout title="دورلي - اطلب الآن" description="اطلب أي منتج أو خدمة من أي مدينة في ليبيا وسنقوم بتوفيرها لك فوراً">
  <style>
    /* يمكنك إضافة أي تنسيقات خاصة بالنموذج هنا */
    .form-step-indicator {
      display: flex;
      justify-content: space-between;
      margin-bottom: 2rem;
      padding: 1rem;
      background: var(--bg-surface);
      border-radius: var(--border-radius);
    }
    .step {
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .step.active {
      color: var(--accent);
      font-weight: bold;
    }
  </style>

  <section class="page-hero">
    <div class="hero-content reveal">
      <h1>ارسل طلبك الآن</h1>
      <p>بضع خطوات بسيطة وسنتولى نحن بقية المهمة</p>
    </div>
  </section>

  <section class="request-form-section">
    <div class="container">
      <div class="request-container reveal">
        <form id="orderForm" class="order-form">
          <div class="form-group">
            <label for="name"><i class="fas fa-user"></i> الاسم الكريم</label>
            <input type="text" id="name" name="name" placeholder="مثلاً: محمد الفيتوري" required>
          </div>

          <div class="form-group">
            <label for="phone"><i class="fas fa-phone"></i> رقم الهاتف (ليبيانا/مدار)</label>
            <input type="tel" id="phone" name="phone" placeholder="09XXXXXXXX" required>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="city"><i class="fas fa-map-marker-alt"></i> مدينة التسليم</label>
              <select id="city" name="city" required>
                <option value="" disabled selected>اختر المدينة</option>
                <option value="بنغازي">بنغازي</option>
                <option value="طرابلس">طرابلس</option>
                <option value="إجدابيا">إجدابيا</option>
                <option value="جالو">جالو</option>
                <option value="أوجلة">أوجلة</option>
                <option value="أجخرة">أجخرة</option>
                <option value="الكفرة">الكفرة</option>
                <option value="طبرق">طبرق</option>
                <option value="البيضاء">البيضاء</option>
                <option value="مصراتة">مصراتة</option>
              </select>
            </div>

            <div class="form-group">
              <label for="category"><i class="fas fa-tag"></i> نوع الطلب</label>
              <select id="category" name="category" required>
                <option value="" disabled selected>اختر الفئة</option>
                <option value="سيارات">قطع غيار سيارات</option>
                <option value="شاحنات">قطع غيار شاحنات</option>
                <option value="مواد غذائية">مواد غذائية وحلويات</option>
                <option value="مستندات">توصيل مستندات وأوراق</option>
                <option value="أخرى">طلب خاص آخر</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="product"><i class="fas fa-pen"></i> تفاصيل الطلب</label>
            <textarea id="product" name="product" placeholder="اكتب بالتفصيل ما الذي تبحث عنه..." required></textarea>
          </div>

          <button type="submit" id="submitBtn" class="submit-btn">
            إرسال الطلب عبر واتساب <i class="fab fa-whatsapp"></i>
          </button>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    // --- ميزة الطلب الذكي: التقاط الفئة من الرابط ---
    document.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const categoryParam = urlParams.get('cat');
      
      if (categoryParam) {
        const categorySelect = document.getElementById('category');
        // محاولة إيجاد الخيار المطابق وتحديده
        for (let i = 0; i < categorySelect.options.length; i++) {
          if (categorySelect.options[i].value === categoryParam) {
            categorySelect.selectedIndex = i;
            // إضافة تأثير بصري بسيط ليعرف المستخدم أنه تم التحديد
            categorySelect.style.borderColor = 'var(--accent)';
            break;
          }
        }
      }
    });

    // --- معالجة إرسال النموذج ---
    document.getElementById('orderForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const name = document.getElementById('name').value;
      const phone = document.getElementById('phone').value;
      const city = document.getElementById('city').value;
      const category = document.getElementById('category').value;
      const product = document.getElementById('product').value;

      // التحقق من رقم الهاتف (Logic الخاص بك)
      const phoneRegex = /^(091|092|094|095)[0-9]{7}$/;
      if (!phoneRegex.test(phone)) {
        alert("يرجى إدخال رقم هاتف ليبي صحيح");
        return;
      }

      const message = `*طلب جديد من دورلي* 📦%0A%0A👤 *الاسم:* ${name}%0A📞 *الهاتف:* ${phone}%0A📍 *المدينة:* ${city}%0A🏷️ *الفئة:* ${category}%0A📝 *التفاصيل:* ${product}`;
      
      window.open(`https://wa.me/218946507954?text=${message}`, '_blank');
    });
  </script>
</Layout>
