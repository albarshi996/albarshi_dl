# ═══════════════════════════════════════════════════════════════════════
# Dawerli Platform — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
#   1. Copy this file → rename to ".env"  (git will ignore it — see .gitignore)
#   2. Fill in your real Firebase values:
#      Firebase Console → Project Settings → Your Apps → SDK setup
#   3. Add each variable as a GitHub Secret for CI/CD:
#      Repo → Settings → Secrets and variables → Actions → New secret
#
# ⚠️  NEVER commit ".env" — it contains real credentials
# ═══════════════════════════════════════════════════════════════════════

# Firebase Project Config
# NOTE: PUBLIC_ prefix is REQUIRED — Astro only exposes PUBLIC_* to browser JS
PUBLIC_FIREBASE_API_KEY=AIzaSy_replace_with_your_real_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:replace_with_real_value
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Auth Plan ────────────────────────────────────────────────────────
# Enable in Firebase Console → Authentication → Sign-in method:
#   ✅ Email/Password  → FREE, unlimited (Spark plan)
#   ✅ Google Sign-In  → FREE, unlimited (Spark plan)
#   ⚠️  Phone OTP/SMS  → ~10/day on Spark → Blaze required for production
